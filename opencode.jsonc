{
  "$schema": "https://opencode.ai/config.json",
"permission": {
    "websearch": "allow"
  },
  "plugin": [
    "@jack-yang/opencode-tps-meter",
    "opencode-model-stats@latest"
  ],
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://192.168.1.33:8080/v1",
        "apiKey": "dummy-key"
      },
      "models": {
        "Qwen3-Coder-Next-Q6_K-00001-of-00003.gguf": {
          "name": "Qwen3-Coder-Next",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "model": "llamacpp/Qwen3-Coder-Next-Q6_K-00001-of-00003.gguf"
}
