{
  "$schema": "https://opencode.ai/config.json",
  "model": "NVIDIA-Nemotron-3-Super-120B-A12B-UD-Q4_K_XL.gguf",
  "compaction": {
    "reserved": 20000,
    "threshold": 0.85
  },
  "provider": {
    "nemotron": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Nemotron 120B (remote)",
      "options": {
        "baseURL": "http://192.168.1.33:8080/v1"
      },
      "models": {
        "NVIDIA-Nemotron-3-Super-120B-A12B-UD-Q4_K_XL.gguf": {
          "name": "NVIDIA-Nemotron-3-Super-120B-A12B-UD-Q4_K_XL.gguf",
          "contextWindow": 65000
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "NVIDIA-Nemotron-3-Super-120B-A12B-UD-Q4_K_XL.gguf",
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "write": "ask",
        "read": "auto",
        "webfetch": "auto",
        "glob": "auto",
        "grep": "auto"
      },
      "tools": {
        "edit": true,
        "write": true,
        "read": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "webfetch": true
      }
    }
  }
}